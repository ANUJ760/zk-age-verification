/* Based on https://github.com/tsconfig/bases/blob/501da2bcd640cf95c95805783e1012b992338f28/bases/node22.json */
{
  "compilerOptions": {
    "lib": ["es2023"],
    "module": "node16",
    "target": "es2022",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "moduleResolution": "node16",
    "types": ["node", "mocha", "chai", "hardhat"],
    "outDir": "dist"
  },
  "include": ["./hardhat.config.ts", "./test/**/*.ts", "./types/**/*.d.ts", "./typechain-types"],
  "exclude": ["./test/Counter.ts", "./scripts/send-op-tx.ts"]
}
